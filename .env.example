# Public site URL (used for OG tags and canonical links)
NEXT_PUBLIC_SITE_URL=https://shabda.app

# MongoDB connection string
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>

# Admin auth — use long random strings (e.g. openssl rand -hex 32)
ADMIN_PASSWORD=change-me-strong-password
ADMIN_SECRET=change-me-random-secret-32-chars

# VAPID push notifications (generate with: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:you@example.com

# Cron job secret — used by /api/cron/daily-push to verify requests from cron services
CRON_SECRET=change-me-random-cron-secret
